    "start": "node dist/cli.js",
    "review": "node dist/cli.js --mode pr"
  },
  "keywords": [
    "code-review",
    "ai",
    "nvidia",
    "gemini",
    "openai",
    "github",
    "gitlab"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
